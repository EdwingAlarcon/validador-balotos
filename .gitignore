# .gitignore

# Dependencias
node_modules/
package-lock.json

# Logs
*.log
npm-debug.log*

# Variables de entorno
.env
.env.local

# Sistema operativo
.DS_Store
Thumbs.db
desktop.ini

# IDEs
.vscode/
.idea/
*.swp
*.swo
*~

# Archivos temporales
*.tmp
*.temp

# SQLite - archivos temporales WAL
*.db-shm
*.db-wal

# Archivos de debug
tests/baloto-panel-debug.html
tests/*.html.backup

# Build (si se agrega)
dist/
build/

# Playwright MCP (capturas de sesión)
.playwright-mcp/
